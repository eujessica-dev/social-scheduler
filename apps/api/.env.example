# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/social_scheduler

# Redis
REDIS_URL=redis://:redis_password@localhost:6379

# JWT
JWT_SECRET=troque-por-um-secret-muito-longo-e-aleatorio-em-producao

# Encryption (AES-256 para tokens OAuth — gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=troque-por-32-bytes-em-hex-na-producao

# Storage (Cloudflare R2 ou AWS S3)
STORAGE_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=sua-access-key
STORAGE_SECRET_ACCESS_KEY=seu-secret-key
STORAGE_BUCKET=social-scheduler-media
STORAGE_PUBLIC_URL=https://media.seudominio.com

# Meta (Facebook/Instagram)
META_APP_ID=seu-app-id
META_APP_SECRET=seu-app-secret
META_REDIRECT_URI=http://localhost:3001/api/v1/social-accounts/meta/callback

# E-mail (Desenvolvimento: MailHog)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@socialscheduler.dev
