generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum OrganizationPlan {
  free
  starter
  pro
  agency
}

enum MemberRole {
  owner
  admin
  editor
  client
  finance
  readonly
}

enum Platform {
  instagram
  facebook
  tiktok
}

enum SocialAccountStatus {
  active
  disconnected
  expired
  error
}

enum MediaStatus {
  uploading
  ready
  error
  deleted
}

enum PostStatus {
  draft
  pending_approval
  approved
  scheduled
  publishing
  published
  failed
  cancelled
}

enum PostPlatformStatus {
  pending
  publishing
  published
  failed
}

enum JobStatus {
  queued
  processing
  completed
  failed
  cancelled
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  cancelled
}

enum BillingGateway {
  stripe
  asaas
  mercadopago
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  passwordHash        String    @map("password_hash")
  emailVerifiedAt     DateTime? @map("email_verified_at")
  twoFactorEnabled    Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret     String?   @map("two_factor_secret")
  avatarUrl           String?   @map("avatar_url")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  memberships         OrganizationMember[]
  refreshTokens       RefreshToken[]
  createdPosts        Post[]               @relation("PostCreatedBy")
  approvedPosts       Post[]               @relation("PostApprovedBy")
  uploadedAssets      MediaAsset[]
  auditLogs           AuditLog[]
  invitedMembers      OrganizationMember[] @relation("InvitedBy")
  apiKeys             ApiKey[]

  @@map("users")
}

// ─────────────────────────────────────────────
// ORGANIZATIONS
// ─────────────────────────────────────────────

model Organization {
  id           String           @id @default(uuid())
  name         String
  slug         String           @unique
  plan         OrganizationPlan @default(free)
  trialEndsAt  DateTime?        @map("trial_ends_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  members        OrganizationMember[]
  brands         Brand[]
  socialAccounts SocialAccount[]
  mediaAssets    MediaAsset[]
  posts          Post[]
  subscription   Subscription?
  auditLogs      AuditLog[]
  whiteLabelSettings WhiteLabelSettings?
  apiKeys        ApiKey[]
  webhooks       Webhook[]

  @@map("organizations")
}

model OrganizationMember {
  id             String      @id @default(uuid())
  organizationId String      @map("organization_id")
  userId         String      @map("user_id")
  role           MemberRole  @default(readonly)
  invitedById    String?     @map("invited_by")
  acceptedAt     DateTime?   @map("accepted_at")
  createdAt      DateTime    @default(now()) @map("created_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy      User?        @relation("InvitedBy", fields: [invitedById], references: [id])

  @@unique([organizationId, userId])
  @@map("organization_members")
}

// ─────────────────────────────────────────────
// BRANDS
// ─────────────────────────────────────────────

model Brand {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  avatarUrl      String?  @map("avatar_url")
  color          String?
  createdById    String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  socialAccounts SocialAccount[]
  mediaAssets    MediaAsset[]
  posts          Post[]

  @@map("brands")
}

// ─────────────────────────────────────────────
// SOCIAL ACCOUNTS & OAUTH
// ─────────────────────────────────────────────

model SocialAccount {
  id               String              @id @default(uuid())
  organizationId   String              @map("organization_id")
  brandId          String?             @map("brand_id")
  platform         Platform
  platformUserId   String              @map("platform_user_id")
  accountName      String              @map("account_name")
  accountAvatar    String?             @map("account_avatar")
  status           SocialAccountStatus @default(active)
  connectedAt      DateTime            @default(now()) @map("connected_at")
  disconnectedAt   DateTime?           @map("disconnected_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brand            Brand?          @relation(fields: [brandId], references: [id])
  oauthToken       OAuthToken?
  postPlatforms    PostPlatform[]
  metricsSnapshots MetricsSnapshot[]

  @@unique([organizationId, platform, platformUserId])
  @@map("social_accounts")
}

model OAuthToken {
  id                     String        @id @default(uuid())
  socialAccountId        String        @unique @map("social_account_id")
  accessTokenEncrypted   String        @map("access_token_encrypted")
  refreshTokenEncrypted  String?       @map("refresh_token_encrypted")
  expiresAt              DateTime?     @map("expires_at")
  scopes                 String[]
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  socialAccount          SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@map("oauth_tokens")
}

// ─────────────────────────────────────────────
// MEDIA LIBRARY
// ─────────────────────────────────────────────

model MediaAsset {
  id             String      @id @default(uuid())
  organizationId String      @map("organization_id")
  brandId        String?     @map("brand_id")
  uploadedById   String      @map("uploaded_by")
  filename       String
  storageKey     String      @map("storage_key")
  mimeType       String      @map("mime_type")
  sizeBytes      BigInt      @map("size_bytes")
  width          Int?
  height         Int?
  durationSeconds Int?       @map("duration_seconds")
  status         MediaStatus @default(uploading)
  createdAt      DateTime    @default(now()) @map("created_at")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brand          Brand?         @relation(fields: [brandId], references: [id])
  uploadedBy     User           @relation(fields: [uploadedById], references: [id])
  postMedia      PostMedia[]

  @@map("media_assets")
}

// ─────────────────────────────────────────────
// POSTS
// ─────────────────────────────────────────────

model Post {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  brandId        String     @map("brand_id")
  title          String?
  caption        String?
  hashtags       String[]
  status         PostStatus @default(draft)
  scheduledAt    DateTime?  @map("scheduled_at")
  timezone       String     @default("America/Sao_Paulo")
  createdById    String     @map("created_by")
  approvedById   String?    @map("approved_by")
  approvedAt     DateTime?  @map("approved_at")
  notes          String?
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brand          Brand          @relation(fields: [brandId], references: [id])
  createdBy      User           @relation("PostCreatedBy", fields: [createdById], references: [id])
  approvedBy     User?          @relation("PostApprovedBy", fields: [approvedById], references: [id])
  media          PostMedia[]
  platforms      PostPlatform[]
  scheduledJob   ScheduledJob?

  @@map("posts")
}

model PostMedia {
  id           String     @id @default(uuid())
  postId       String     @map("post_id")
  mediaAssetId String     @map("media_asset_id")
  order        Int        @default(0)

  post         Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id])

  @@unique([postId, mediaAssetId])
  @@map("post_media")
}

model PostPlatform {
  id               String             @id @default(uuid())
  postId           String             @map("post_id")
  socialAccountId  String             @map("social_account_id")
  platform         Platform
  platformPostId   String?            @map("platform_post_id")
  status           PostPlatformStatus @default(pending)
  errorMessage     String?            @map("error_message")
  errorCode        String?            @map("error_code")
  publishedAt      DateTime?          @map("published_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  post             Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  socialAccount    SocialAccount     @relation(fields: [socialAccountId], references: [id])
  publishingLogs   PublishingLog[]
  metricsSnapshots MetricsSnapshot[]

  @@map("post_platforms")
}

// ─────────────────────────────────────────────
// SCHEDULER & WORKERS
// ─────────────────────────────────────────────

model ScheduledJob {
  id           String    @id @default(uuid())
  postId       String    @unique @map("post_id")
  queueJobId   String?   @map("queue_job_id")
  status       JobStatus @default(queued)
  attempts     Int       @default(0)
  lastAttemptAt DateTime? @map("last_attempt_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  post         Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("scheduled_jobs")
}

model PublishingLog {
  id              String       @id @default(uuid())
  postPlatformId  String       @map("post_platform_id")
  attemptNumber   Int          @map("attempt_number")
  requestPayload  Json?        @map("request_payload")
  responsePayload Json?        @map("response_payload")
  httpStatus      Int?         @map("http_status")
  durationMs      Int?         @map("duration_ms")
  success         Boolean
  createdAt       DateTime     @default(now()) @map("created_at")

  postPlatform    PostPlatform @relation(fields: [postPlatformId], references: [id], onDelete: Cascade)

  @@map("publishing_logs")
}

// ─────────────────────────────────────────────
// METRICS
// ─────────────────────────────────────────────

model MetricsSnapshot {
  id              String       @id @default(uuid())
  postPlatformId  String?      @map("post_platform_id")
  socialAccountId String       @map("social_account_id")
  collectedAt     DateTime     @default(now()) @map("collected_at")
  reach           Int?
  impressions     Int?
  likes           Int?
  comments        Int?
  shares          Int?
  saves           Int?
  views           Int?
  clicks          Int?
  engagementRate  Decimal?     @map("engagement_rate") @db.Decimal(5, 4)
  rawData         Json?        @map("raw_data")

  postPlatform    PostPlatform?  @relation(fields: [postPlatformId], references: [id])
  socialAccount   SocialAccount  @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@map("metrics_snapshots")
}

// ─────────────────────────────────────────────
// BILLING
// ─────────────────────────────────────────────

model Subscription {
  id                     String             @id @default(uuid())
  organizationId         String             @unique @map("organization_id")
  plan                   OrganizationPlan
  status                 SubscriptionStatus @default(trialing)
  gateway                BillingGateway
  gatewaySubscriptionId  String?            @map("gateway_subscription_id")
  gatewayCustomerId      String?            @map("gateway_customer_id")
  currentPeriodStart     DateTime?          @map("current_period_start")
  currentPeriodEnd       DateTime?          @map("current_period_end")
  cancelledAt            DateTime?          @map("cancelled_at")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  organization           Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  tokenHash   String    @map("token_hash")
  familyId    String    @map("family_id")
  deviceInfo  String?   @map("device_info")
  ipAddress   String?   @map("ip_address")
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// AUDIT & SECURITY
// ─────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  userId         String?  @map("user_id")
  action         String
  entityType     String?  @map("entity_type")
  entityId       String?  @map("entity_id")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// API KEYS
// ─────────────────────────────────────────────

model ApiKey {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  name           String
  keyHash        String    @map("key_hash")
  lastUsedAt     DateTime? @map("last_used_at")
  expiresAt      DateTime? @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  createdById    String    @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User         @relation(fields: [createdById], references: [id])

  @@map("api_keys")
}

// ─────────────────────────────────────────────
// WEBHOOKS
// ─────────────────────────────────────────────

model Webhook {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  url            String
  secret         String
  events         String[]
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("webhooks")
}

// ─────────────────────────────────────────────
// WHITE LABEL
// ─────────────────────────────────────────────

model WhiteLabelSettings {
  id                String   @id @default(uuid())
  organizationId    String   @unique @map("organization_id")
  customDomain      String?  @map("custom_domain")
  logoUrl           String?  @map("logo_url")
  faviconUrl        String?  @map("favicon_url")
  primaryColor      String?  @map("primary_color")
  secondaryColor    String?  @map("secondary_color")
  emailSenderName   String?  @map("email_sender_name")
  emailSenderDomain String?  @map("email_sender_domain")
  hideBranding      Boolean  @default(false) @map("hide_branding")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("white_label_settings")
}
